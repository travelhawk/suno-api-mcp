# ──────────────────────────────────────────────────────────────────────────────
# suno-api-mcp — environment configuration
# Copy this file to .env and fill in your values.
# When running via Claude Desktop, pass these in the MCP server's "env" block.
# ──────────────────────────────────────────────────────────────────────────────

# Required: your sunoapi.org Bearer token.
# Get one at https://sunoapi.org/dashboard
SUNOAPI_KEY=your_api_key_here
