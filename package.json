{
  "name": "suno-api-mcp",
  "version": "1.0.0",
  "description": "MCP server for Suno AI music generation via sunoapi.org",
  "type": "module",
  "bin": {
    "suno-mcp": "./dist/server.cjs"
  },
  "scripts": {
    "prepare": "node build.mjs",
    "build": "node build.mjs",
    "dev": "node --env-file .env --import tsx/esm src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/travelhawk/suno-api-mcp.git"
  },
  "keywords": ["mcp", "suno", "music", "ai", "modelcontextprotocol"],
  "engines": {
    "node": ">=22"
  }
}
